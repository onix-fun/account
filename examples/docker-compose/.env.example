# Copy to .env and replace every CHANGE_ME value.
PUBLIC_BASE_URL=https://account.example.com
ACCOUNT_ALLOWED_ORIGINS=https://account.example.com
ACCOUNT_TRUSTED_PROXY_CIDRS=10.0.0.0/8
IDENTITY_OTP_HMAC_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
IDENTITY_INTERNAL_AUTH_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS

# Database
DB_URL=jdbc:postgresql://account-postgres:5432/account
DB_NAME=account
DB_USER=account
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

# SMTP with STARTTLS
IDENTITY_SMTP_HOST=smtp.example.com
IDENTITY_SMTP_PORT=587
IDENTITY_SMTP_FROM=no-reply@example.com
IDENTITY_SMTP_USERNAME=CHANGE_ME_SMTP_USERNAME
IDENTITY_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD

# Object storage
S3_ACCESS_KEY=account-minio
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# Image tag
TAG=latest
