# Immutable application images published by GitHub Actions
ACCOUNT_GATEWAY_IMAGE=ghcr.io/owner/repository/gateway:1.0.0
ACCOUNT_FRONTEND_IMAGE=ghcr.io/owner/repository/frontend:1.0.0
ACCOUNT_BACKEND_IMAGE=ghcr.io/owner/repository/backend:1.0.0

# Ports
ACCOUNT_GATEWAY_HTTP_PORT=8089
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
MAIL_SMTP_PORT=1026
MAIL_UI_PORT=8026
GRAFANA_PORT=3000

# Database
POSTGRES_DB=account
POSTGRES_USER=account
POSTGRES_PASSWORD=account

# Redis
IDENTITY_REDIS_PASSWORD=account-redis-secret

# S3 / MinIO
S3_ACCESS_KEY=account-minio
S3_SECRET_KEY=account-minio-secret

# Secrets (override for production)
IDENTITY_INTERNAL_AUTH_SECRET=local-test-internal-secret-32chars!
IDENTITY_OTP_HMAC_SECRET=local-test-otp-secret-32chars!!
CLICKHOUSE_USER=otel
CLICKHOUSE_PASSWORD=replace-with-clickhouse-password
GRAFANA_ADMIN_PASSWORD=replace-with-grafana-password
