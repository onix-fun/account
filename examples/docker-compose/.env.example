ACCOUNT_FRONTEND_IMAGE=ghcr.io/onix-fun/accaunt/frontend:1.0.0
ACCOUNT_BACKEND_IMAGE=ghcr.io/onix-fun/accaunt/backend:1.0.0
# Use `always` after the first stable images are published.
ACCOUNT_PULL_POLICY=build
ACCOUNT_HTTP_PORT=8089
ACCOUNT_MAIL_UI_PORT=8026
ACCOUNT_DATABASE_PASSWORD=change-me-database
ACCOUNT_REDIS_PASSWORD=change-me-redis
ACCOUNT_S3_ACCESS_KEY=account
ACCOUNT_S3_SECRET_KEY=change-me-s3-secret
ACCOUNT_SECURITY_OTP_HMAC_SECRET=change-me-otp-secret-at-least-32-characters
ACCOUNT_SECURITY_INTERNAL_AUTH_SECRET=change-me-internal-secret-at-least-32-characters
ACCOUNT_HTTP_ALLOWED_ORIGINS=http://localhost:8089
ACCOUNT_TRUSTED_REDIRECT_ORIGINS=
